PORT=5000
NODE_ENV=development

# Database (if needed in future)
# DATABASE_URL=mongodb://localhost:27017/ghostskill

# AI API Keys
# Google Gemini API (Primary)
GOOGLE_API_KEY=your_google_api_key_here

# Alternative AI APIs (optional)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama API Configuration (Default Local)
USE_OLLAMA=true
OLLAMA_API_URL=http://localhost:11434
# Available models: phi3, gemma3:4b, llama3.2, qwen3:4b
OLLAMA_MODEL=llama3.2

# JWT Secret (for authentication)
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Python Wisdom API
PYTHON_API_URL=http://localhost:8000

# Chat Logging (Beta Feature)
# Set to 'true' to enable chat conversation logging for developer analysis
# Logs will be saved to: backend/chat-logs/
ENABLE_CHAT_LOGGING=false
